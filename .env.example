# LLM-Bench API Keys
# Copy this to .env and fill in your keys
# The runner reads these from environment variables

# OpenAI — https://platform.openai.com/api-keys
# Models: gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o3, o4-mini
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com/settings/keys
# Models: claude-opus-4, claude-sonnet-4, claude-haiku-4
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/apikey
# Models: gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash
GEMINI_API_KEY=AI...

# DeepSeek — https://platform.deepseek.com/api_keys
# Models: deepseek-chat, deepseek-reasoner
DEEPSEEK_API_KEY=sk-...

# Web Server Upload (for sending results from desktop to server)
LLMBENCH_UPLOAD_URL=https://simonmccallum.org.nz/bench
UPLOAD_API_KEY=<generate-from-admin-panel-or-set-same-as-ADMIN_PASSWORD>

# Admin panel password (for web server)
ADMIN_PASSWORD=changeme
SECRET_KEY=<random-hex-string-for-flask-sessions>

# HuggingFace (for gated models like Llama)
# HF_TOKEN=hf_...
