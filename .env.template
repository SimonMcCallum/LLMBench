# ============================================================
# LLM-Bench Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# The .env file is gitignored and should NEVER be committed.
# ============================================================

# ---- Web Server / Admin Panel ----
ADMIN_PASSWORD=change-me-to-a-strong-password
SECRET_KEY=generate-with-python-c-import-secrets-secrets.token_hex-32

# ---- OpenAI ----
# Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_API_KEY=sk-...

# ---- Anthropic (Claude) ----
# Models: claude-sonnet-4-20250514, claude-haiku-4-20250414
ANTHROPIC_API_KEY=sk-ant-...

# ---- Google Gemini ----
# Models: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
GEMINI_API_KEY=AI...

# ---- DeepSeek ----
# Models: deepseek-chat, deepseek-reasoner
DEEPSEEK_API_KEY=sk-...

# ---- HuggingFace (for gated models like Llama) ----
# Only needed if running local models that require authentication
# HF_TOKEN=hf_...
