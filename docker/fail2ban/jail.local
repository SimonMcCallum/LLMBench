[DEFAULT]
bantime = 3600
findtime = 600
maxretry = 5
banaction = iptables-multiport

[nginx-botsearch]
enabled = true
port = http,https
filter = nginx-botsearch
logpath = /var/log/nginx/access.log
maxretry = 3
bantime = 3600

[llm-bench-login]
enabled = true
port = http,https
filter = llm-bench-login
logpath = /var/log/nginx/access.log
maxretry = 5
findtime = 300
bantime = 1800
